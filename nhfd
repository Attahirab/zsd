<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Colors</title><style>body{background:#000;color:#fff;text-align:center;padding:50px;}#palettes{display:flex;justify-content:center;gap:20px;flex-wrap:wrap;}</style></head><body><h1>🎨 Random Palette</h1><button onclick="generate()">New Palette</button><div id="palettes"></div><script>function randomColor(){return '#'+Math.floor(Math.random()*16777215).toString(16);}function generate(){const div=document.getElementById('palettes');div.innerHTML='';for(let i=0;i<5;i++){const c=randomColor();const box=document.createElement('div');box.style.background=c;box.style.width='100px';box.style.height='100px';box.style.borderRadius='10px';box.onclick=()=>navigator.clipboard.writeText(c);div.appendChild(box);}}</script></body></html>
